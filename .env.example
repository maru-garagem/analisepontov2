# ============================================================
# PontoExtract v2 — Environment Variables
# ============================================================
# Copie este arquivo para .env e preencha com valores reais.
# O arquivo .env é IGNORADO pelo git. NUNCA comite segredos.

# ----- Core -----
ENV=development
LOG_LEVEL=INFO
PORT=8000

# ----- Database -----
# Railway: ao adicionar o serviço PostgreSQL, DATABASE_URL é injetado automaticamente.
# Local (docker-compose): use a URL do Postgres do compose.
# Para rodar sem Docker, deixe vazio e o sistema cai em SQLite (./dev.db) — apenas para testes rápidos.
DATABASE_URL=postgresql://ponto:ponto_dev@db:5432/pontoextract

# ----- Auth -----
# ACCESS_PASSWORD: mínimo 16 caracteres. Senha única de acesso ao painel.
ACCESS_PASSWORD=troque_isto_para_senha_com_minimo_16_caracteres
# SESSION_SECRET: mínimo 32 caracteres aleatórios.
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=troque_isto_por_string_aleatoria_de_pelo_menos_32_caracteres

# ----- LLM (OpenRouter) -----
OPENROUTER_API_KEY=sk-or-v1-REPLACE
OPENROUTER_MODEL_POTENTE=x-ai/grok-4
OPENROUTER_MODEL_BARATO=x-ai/grok-4-fast

# ----- Uploads -----
MAX_UPLOAD_SIZE_MB=20

# ----- Integrations -----
# URL padrão para webhook de integração (opcional).
DEFAULT_WEBHOOK_URL=
# CORS: domínios permitidos, separados por vírgula. Vazio = mesmo-origem apenas.
ALLOWED_ORIGINS=

# ----- Conformidade de extração -----
# Score mínimo para aceitar extração silenciosamente (0.0 a 1.0).
SCORE_CONFORMIDADE_MIN=0.85
# Abaixo deste score, a extração é marcada como "sucesso com aviso".
SCORE_CONFORMIDADE_ALERTA=0.70
# Se a taxa de sucesso de um esqueleto cai abaixo disso, vira "em_revisao".
TAXA_SUCESSO_MIN_ESQUELETO=0.70
